# Файл конфигурации Apache для NewCSSLearn
# Настройки для производственного хостинга Hoster.kz

# Включение механизма URL rewriting
RewriteEngine On

# RewriteBase не используется - правила работают универсально
# как для локальной разработки (корень), так и для хостинга (поддиректория)
# RewriteBase para hosting em subdiretório /new-css-learn/
# Para desenvolvimento local comente a linha abaixo
# RewriteBase /new-css-learn/

# Прямой доступ к существующим файлам и директориям
RewriteCond %{REQUEST_FILENAME} -f [OR]
RewriteCond %{REQUEST_FILENAME} -d
RewriteRule ^ - [L]

# Правила для админ-панели
RewriteRule ^bod/?$ admin/index.php [L]
RewriteRule ^bod/login/?$ admin/login.php [L]
RewriteRule ^bod/lessons/?$ admin/lessons.php [L]
RewriteRule ^bod/lessons/([0-9]+)/?$ admin/lessons.php?section=$1 [L]
RewriteRule ^bod/section/edit/([0-9]+)/?$ admin/edit-section.php?id=$1 [L]
RewriteRule ^bod/section/new/?$ admin/edit-section.php [L]
RewriteRule ^bod/sections/?$ admin/sections.php [L]
RewriteRule ^bod/lesson/edit/([0-9]+)/?$ admin/edit-lesson.php?id=$1 [L]
RewriteRule ^bod/lesson/new/([0-9]+)/?$ admin/edit-lesson.php?section=$1 [L]
RewriteRule ^bod/lesson/new/?$ admin/edit-lesson.php [L]
RewriteRule ^bod/upload/?$ admin/upload.php [L]
RewriteRule ^bod/admin/save-draft/?$ admin/save-draft.php [L]

# Правила для загрузки изображений
RewriteRule ^uploads/([0-9]+)/images/(.+)$ uploads/$1/images/$2 [L]

# Прямой доступ к assets директории (CSS, JS, изображения)
RewriteRule ^assets/ - [L]

# Все остальные запросы перенаправляем на index.php
RewriteRule ^(.*)$ index.php [L]

# Установка кодировки
AddDefaultCharset UTF-8
AddType 'text/html; charset=UTF-8' .html

# Защита от доступа к системным файлам
<Files ~ "^\.">
    Require all denied
</Files>

<Files ~ "^(config|functions|Database|Router)\.php$">
    Require all denied
</Files>

# Защита от доступа к конфигурационным файлам
<FilesMatch "\.(env|log|ini|conf)$">
    Require all denied
</FilesMatch>

# Отключение просмотра каталогов
Options -Indexes

# Защита от XSS атак
<IfModule mod_headers.c>
    Header always set X-Content-Type-Options nosniff
    Header always set X-Frame-Options DENY
    Header always set X-XSS-Protection "1; mode=block"
    Header always set Referrer-Policy "strict-origin-when-cross-origin"
</IfModule>

# Настройка кэширования статических файлов
<IfModule mod_expires.c>
    ExpiresActive On
    ExpiresByType text/css "access plus 1 month"
    ExpiresByType application/javascript "access plus 1 month"
    ExpiresByType image/png "access plus 1 month"
    ExpiresByType image/jpg "access plus 1 month"
    ExpiresByType image/jpeg "access plus 1 month"
    ExpiresByType image/gif "access plus 1 month"
    ExpiresByType image/svg+xml "access plus 1 month"
    ExpiresByType image/webp "access plus 1 month"
</IfModule>

# Сжатие статических файлов
<IfModule mod_deflate.c>
    AddOutputFilterByType DEFLATE text/plain
    AddOutputFilterByType DEFLATE text/html
    AddOutputFilterByType DEFLATE text/xml
    AddOutputFilterByType DEFLATE text/css
    AddOutputFilterByType DEFLATE application/xml
    AddOutputFilterByType DEFLATE application/xhtml+xml
    AddOutputFilterByType DEFLATE application/rss+xml
    AddOutputFilterByType DEFLATE application/javascript
    AddOutputFilterByType DEFLATE application/x-javascript
</IfModule>
